# HTTP server
PORT=3000

# Max body size for JSON and urlencoded (default 1mb if unset).
# REQUEST_BODY_LIMIT=1mb

# Behind nginx / load balancer: set hop count so req.ip and rate limits use real client IP.
# Examples: TRUST_PROXY=1  or  TRUST_PROXY=true  (same as 1). Omit or false for local direct access.
# TRUST_PROXY=1

# Logging (pino): fatal | error | warn | info | debug | trace | silent
# LOG_LEVEL=info

# Rate limit (per IP, sliding window). /health is excluded.
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=300

# CORS: comma-separated origins, e.g. https://app.example.com,http://localhost:5173
# In development, if unset, any origin is allowed. In production, unset means disabled.
# CORS_ORIGIN=http://localhost:5173
# CORS_CREDENTIALS=true

# MongoDB (required in all environments). Same URI for app, migrate-mongo, and seed.
MONGODB_URI=mongodb://127.0.0.1:27017/ecommerce

# Public prefix for versioned REST API (must start with /, no ..). Default: /api/v1
# API_V1_PREFIX=/api/v1

# Auth/JWT settings
# JWT_ACCESS_SECRET=replace-with-strong-secret
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_SECRET=replace-with-another-strong-secret
# JWT_REFRESH_TTL=7d

# DB: npm run db:migrate | db:migrate:status | db:seed (see README; needs Mongo running)
 