# HTTP server
PORT=3000

# Max body size for JSON and urlencoded (default 1mb if unset).
# REQUEST_BODY_LIMIT=1mb

# Behind nginx / load balancer: set hop count so req.ip and rate limits use real client IP.
# Examples: TRUST_PROXY=1  or  TRUST_PROXY=true  (same as 1). Omit or false for local direct access.
# TRUST_PROXY=1

# Logging (pino): fatal | error | warn | info | debug | trace | silent
# LOG_LEVEL=info

# Rate limit (per IP, sliding window). /health is excluded.
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=300
# Optional: Redis for shared counters behind multiple replicas (redis:// or rediss://). Omit = in-memory per process.
# RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379

# CORS: comma-separated origins, e.g. https://app.example.com,http://localhost:5173
# In development, if unset, any origin is allowed. In production, unset means disabled.
# CORS_ORIGIN=http://localhost:5173
# CORS_CREDENTIALS=true

# MongoDB (required in all environments). Same URI for app, migrate-mongo, and seed.
MONGODB_URI=mongodb://127.0.0.1:27017/ecommerce

# Public prefix for versioned REST API (must start with /, no ..). Default: /api/v1
# API_V1_PREFIX=/api/v1

# Reported to clients (errors, health, sample JSON responses) and sent as X-API-Version on versioned routes.
# API_VERSION=1

# Swagger UI at /docs. Defaults: enabled when NODE_ENV is not production; set to true/false to override.
# API_DOCS_ENABLED=true

# Optional commit or build id for /health (e.g. inject in CI/CD).
# GIT_SHA=abc1234

# Auth/JWT — required in every environment (no code defaults). Use strong random values in production.
JWT_ACCESS_SECRET=replace-with-strong-secret-for-local-dev
JWT_REFRESH_SECRET=replace-with-a-different-strong-secret
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL=7d

# DB: npm run db:migrate | db:migrate:status | db:seed (see README; needs Mongo running)

# --- Observability (optional; defaults keep instrumentation off) ---
# OpenTelemetry tracing (HTTP + Express + MongoDB driver). First import in server.ts when enabled.
# OBSERVABILITY_TRACING_ENABLED=true
# OBSERVABILITY_TRACING_EXPORTER=console
# OTLP example (Jaeger / Collector HTTP): set exporter to otlp and provide the full traces URL.
# OBSERVABILITY_TRACING_EXPORTER=otlp
# OBSERVABILITY_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces
# OBSERVABILITY_SERVICE_NAME=http-api
# Root trace sampling probability 0–1 (default 0.1). Uses ParentBased + TraceIdRatio; respects upstream sampled flag.
# OBSERVABILITY_TRACE_SAMPLING_RATIO=0.1
# Mask client IP on spans (IPv4 last octet -> 0; IPv6 truncated) when true.
# OBSERVABILITY_ANONYMIZE_IP=true

# Prometheus text at GET /metrics (no auth; excluded from rate limit when enabled).
# OBSERVABILITY_METRICS_ENABLED=true
