{
  "name": "http-api-boilerplate",
  "version": "0.1.0",
  "private": true,
  "description": "Node.js HTTP API template: Express 5, TypeScript, MongoDB, Zod, OpenAPI, tests, Docker.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <23"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run lint && npm run test:ci && npm run typecheck:frontend && npm run build && npm run openapi:check",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "db:migrate": "node --import tsx ./node_modules/migrate-mongo/bin/migrate-mongo.js up -f migrate-mongo-config.ts",
    "db:migrate:down": "node --import tsx ./node_modules/migrate-mongo/bin/migrate-mongo.js down -f migrate-mongo-config.ts",
    "db:migrate:status": "node --import tsx ./node_modules/migrate-mongo/bin/migrate-mongo.js status -f migrate-mongo-config.ts",
    "db:migrate:create": "node --import tsx ./node_modules/migrate-mongo/bin/migrate-mongo.js create -f migrate-mongo-config.ts",
    "db:seed": "tsx src/database/seed.ts",
    "openapi:generate": "cross-env MONGODB_URI=mongodb://127.0.0.1:27017/openapi-codegen JWT_ACCESS_SECRET=01234567890123456789012345678901 JWT_REFRESH_SECRET=01234567890123456789012345678902 tsx scripts/openapi-generate.ts",
    "openapi:check": "cross-env MONGODB_URI=mongodb://127.0.0.1:27017/openapi-codegen JWT_ACCESS_SECRET=01234567890123456789012345678901 JWT_REFRESH_SECRET=01234567890123456789012345678902 tsx scripts/openapi-check.ts",
    "typecheck:frontend": "tsc -p tsconfig.frontend.json",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,mjs,cjs}": [
      "prettier --write",
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ],
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.17",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "migrate-mongo": "^14.0.7",
    "mongodb-memory-server": "^11.0.1",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.6.2",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/instrumentation-express": "^0.63.0",
    "@opentelemetry/instrumentation-http": "^0.215.0",
    "@opentelemetry/instrumentation-mongodb": "^0.68.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "openapi-fetch": "^0.17.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "redis": "^4.7.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  }
}
